{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:cloud-run": "tsc --project tsconfig.cloud-run.json --noEmit && vite build --config vite.cloud-run.config.ts",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:cloud-run:foundation": "npm run build:cloud-run && node work/cloud-run/cloud-run-server.mjs",
    "test": "npm run build && npm run build:cloud-run && node --experimental-strip-types --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern work",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.local.jsonc",
    "db:migrate:postgres": "npm run build:cloud-run && node work/cloud-run/run-migrations.mjs",
    "db:rehearse:postgres-core": "npm run build:cloud-run && node work/cloud-run/run-core-rehearsal.mjs",
    "e2e:db:prepare": "npm run db:migrate:local && wrangler d1 execute DB --local --config wrangler.local.jsonc --file tests/e2e/fixtures/seed.sql",
    "e2e:server": "npm run e2e:db:prepare && vinext dev --host 127.0.0.1 --port 4173",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "1.11.2",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pg": "8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
