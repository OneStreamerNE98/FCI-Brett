# Office access (the signed-in FCI app user is separate from the Google Workspace connection)
FCI_OFFICE_EMAILS=
FCI_OFFICE_DOMAINS=
FCI_ADMIN_EMAILS=

# Local `npm run dev` only. Ignored by hosted production builds.
FCI_LOCAL_DEV_USER_EMAIL=

# `simulation` uses local sample Gmail, Calendar, Shared Drive, and Sheets data.
# `workspace` enables the single company Google Workspace connection below.
GOOGLE_INTEGRATION_MODE=simulation

# Company Google Workspace connection. These values are ignored in simulation mode.
GOOGLE_WORKSPACE_ENABLED_SERVICES=drive,gmail,calendar,sheets
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY=
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY_VERSION=1
GOOGLE_WORKSPACE_ALLOWED_DOMAINS=cherryhillfci.com
GOOGLE_WORKSPACE_AUTHORIZED_ACCOUNTS=
GOOGLE_WORKSPACE_SHARED_DRIVE_ID=
GOOGLE_WORKSPACE_DRIVE_PROVISIONING_ENABLED=false
GOOGLE_WORKSPACE_CLIENT_DIRECTORY_SHEET_ID=
GOOGLE_WORKSPACE_INTAKE_MAILBOX=
GOOGLE_WORKSPACE_CLIENT_APPOINTMENTS_CALENDAR_ID=
GOOGLE_WORKSPACE_FIELD_SCHEDULE_CALENDAR_ID=
GOOGLE_WORKSPACE_PUBSUB_TOPIC=

# OpenAI project assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
