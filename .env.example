# Office access (set the ChatGPT account email(s) that may administer Google connections)
FCI_OFFICE_EMAILS=
FCI_OFFICE_DOMAINS=
FCI_ADMIN_EMAILS=

# Local `npm run dev` only. Ignored by hosted production builds.
FCI_LOCAL_DEV_USER_EMAIL=

# Google connection profiles. Keep personal testing and company production separate.
GOOGLE_CONNECTION_ENVIRONMENT=test

# Personal test profile — use only a dedicated test folder, sample documents, and a personal test account.
GOOGLE_TEST_CLIENT_ID=
GOOGLE_TEST_CLIENT_SECRET=
GOOGLE_TEST_OAUTH_REDIRECT_URI=
GOOGLE_TEST_TOKEN_ENCRYPTION_KEY=
GOOGLE_TEST_TOKEN_ENCRYPTION_KEY_VERSION=1
GOOGLE_TEST_DRIVE_MODE=my-drive
GOOGLE_TEST_DRIVE_ROOT_FOLDER_ID=
GOOGLE_TEST_SHARED_DRIVE_ID=
GOOGLE_TEST_AUTHORIZED_ACCOUNT_EMAILS=
GOOGLE_TEST_MY_DRIVE_BROAD_SCOPE_ACKNOWLEDGED=false
GOOGLE_TEST_DRIVE_PROVISIONING_ENABLED=false
GOOGLE_TEST_CLIENT_DIRECTORY_SHEET_ID=
GOOGLE_TEST_INTAKE_MAILBOX=
GOOGLE_TEST_CLIENT_APPOINTMENTS_CALENDAR_ID=
GOOGLE_TEST_FIELD_SCHEDULE_CALENDAR_ID=
GOOGLE_TEST_PUBSUB_TOPIC=

# Company production profile — use a distinct OAuth client, company Google account, and Shared Drive.
GOOGLE_PRODUCTION_CLIENT_ID=
GOOGLE_PRODUCTION_CLIENT_SECRET=
GOOGLE_PRODUCTION_OAUTH_REDIRECT_URI=
GOOGLE_PRODUCTION_TOKEN_ENCRYPTION_KEY=
GOOGLE_PRODUCTION_TOKEN_ENCRYPTION_KEY_VERSION=1
GOOGLE_PRODUCTION_DRIVE_MODE=shared-drive
GOOGLE_PRODUCTION_DRIVE_ROOT_FOLDER_ID=
GOOGLE_PRODUCTION_SHARED_DRIVE_ID=
GOOGLE_PRODUCTION_AUTHORIZED_ACCOUNT_EMAILS=
GOOGLE_PRODUCTION_MY_DRIVE_BROAD_SCOPE_ACKNOWLEDGED=false
GOOGLE_PRODUCTION_DRIVE_PROVISIONING_ENABLED=false
GOOGLE_PRODUCTION_CLIENT_DIRECTORY_SHEET_ID=
GOOGLE_PRODUCTION_INTAKE_MAILBOX=
GOOGLE_PRODUCTION_CLIENT_APPOINTMENTS_CALENDAR_ID=
GOOGLE_PRODUCTION_FIELD_SCHEDULE_CALENDAR_ID=
GOOGLE_PRODUCTION_PUBSUB_TOPIC=

# The Drive-only release deliberately has no Gmail/Calendar/Sheets feature flag.
# Future adapters must use the profile-specific values above and request consent separately.

# OpenAI project assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
