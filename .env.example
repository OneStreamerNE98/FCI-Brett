# Office access (the signed-in FCI app user is separate from the Google Workspace connection)
FCI_OFFICE_EMAILS=
FCI_OFFICE_DOMAINS=
FCI_ADMIN_EMAILS=

# Explicit application environment identity. The Sites deployment uses development.
# The later Google Cloud deployment will set this to production.
FCI_APP_ENVIRONMENT=development

# Source-only Google Cloud runtime foundation. These values are ignored by the
# current Sites/D1 development command. Google Cloud commands require
# FCI_APP_ENVIRONMENT=production and fail closed when any required value is
# missing. Configure exactly one password source through Secret Manager.
FCI_DEPLOYMENT_STAGE=dev
FCI_POSTGRES_ACCESS_MODE=runtime
FCI_POSTGRES_CONNECTION_MODE=cloud-sql-connector
FCI_CLOUD_SQL_INSTANCE_CONNECTION_NAME=
FCI_CLOUD_SQL_IP_TYPE=PRIVATE
FCI_POSTGRES_DATABASE=
FCI_POSTGRES_USER=
FCI_POSTGRES_PASSWORD=
FCI_POSTGRES_PASSWORD_FILE=
FCI_POSTGRES_SCHEMA=fci_app
FCI_POSTGRES_MIGRATION_ROLE=
FCI_POSTGRES_POOL_MAX=5
FCI_POSTGRES_CONNECTION_TIMEOUT_MS=5000
FCI_POSTGRES_IDLE_TIMEOUT_MS=30000
FCI_POSTGRES_MAX_LIFETIME_SECONDS=1800
FCI_POSTGRES_STATEMENT_TIMEOUT_MS=30000
FCI_POSTGRES_QUERY_TIMEOUT_MS=35000
FCI_POSTGRES_LOCK_TIMEOUT_MS=5000
FCI_POSTGRES_IDLE_TRANSACTION_TIMEOUT_MS=30000
FCI_POSTGRES_KEEPALIVE_INITIAL_DELAY_MS=10000
FCI_REHEARSAL_ACKNOWLEDGMENT=

# Local `npm run dev` only. Ignored by hosted production builds.
FCI_LOCAL_DEV_USER_EMAIL=

# `simulation` uses local sample Gmail, Calendar, Shared Drive, and Sheets data.
# `workspace` enables the single company Google Workspace connection below.
GOOGLE_INTEGRATION_MODE=simulation

# Company Google Workspace connection. These values are ignored in simulation mode.
GOOGLE_WORKSPACE_ENABLED_SERVICES=drive,gmail,calendar,sheets
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY=
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY_VERSION=1
GOOGLE_WORKSPACE_ALLOWED_DOMAINS=cherryhillfci.com
# When Gmail is enabled, configure exactly one authorized account and use that
# same address for the intake mailbox. Gmail operates as the connected account.
GOOGLE_WORKSPACE_AUTHORIZED_ACCOUNTS=
GOOGLE_WORKSPACE_SHARED_DRIVE_ID=
GOOGLE_WORKSPACE_DRIVE_PROVISIONING_ENABLED=false
GOOGLE_WORKSPACE_CLIENT_DIRECTORY_SHEET_ID=
GOOGLE_WORKSPACE_INTAKE_MAILBOX=
GOOGLE_WORKSPACE_CLIENT_APPOINTMENTS_CALENDAR_ID=
GOOGLE_WORKSPACE_FIELD_SCHEDULE_CALENDAR_ID=

# OpenAI project assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
